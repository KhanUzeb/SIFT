
# --- LLM: agent loop (tool-calling decisions) ---
# Optional overrides; leave blank to use the shared LLM_* values above.
LOOP_LLM_API_KEY=
LOOP_LLM_BASE_URL=
LOOP_LLM_MODEL=

# --- LLM: summarizer / merge (plain text generation) ---
# Optional overrides; leave blank to use the shared LLM_* values above.
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL=

# --- Local LLM override ---
USE_LOCAL_LLM=false
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=llama3.1

# --- Search ---
TAVILY_API_KEY=tvly-...

# --- Agent loop ---
MAX_STEPS=5
MIN_SEARCH_RESULTS=3
MAX_SEARCH_RESULTS=8

# --- Reader ---
FETCH_TIMEOUT_SECONDS=7
MAX_CONCURRENT_FETCHES=5

# --- Summarizer ---
CHUNK_SIZE_TOKENS=2000
CHUNK_OVERLAP_TOKENS=80
MAX_PAGES_TO_SUMMARIZE=2
MAX_PAGE_CHARS_TO_SUMMARIZE=8000

# --- Storage ---
NOTES_PATH=data/notes.json
LOG_LEVEL=INFO
